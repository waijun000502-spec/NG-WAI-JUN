rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "waijun000502@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'age', 'occupation', 'whatsapp', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.age is string && data.age.size() > 0 && data.age.size() <= 20 &&
             data.occupation is string && data.occupation.size() > 0 && data.occupation.size() <= 100 &&
             data.whatsapp is string && data.whatsapp.size() > 0 && data.whatsapp.size() <= 30 &&
             data.createdAt == request.time;
    }

    match /enquiries/{enquiryId} {
      // Anyone can create an enquiry
      allow create: if isValidId(enquiryId) && isValidEnquiry(incoming());
      
      // Only Admin can read
      allow read, update, delete: if isAdmin();
    }
  }
}
